# Copy to .env and fill in. Anything not set falls back to a sensible dev default.

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+psycopg://depart_user:depart_secure_password@localhost:5432/depart
DB_PASSWORD=depart_secure_password

# ─── API runtime ─────────────────────────────────────────────────────────────
ENVIRONMENT=development
API_HOST=0.0.0.0
API_PORT=8000
MAX_UPLOAD_SIZE=52428800     # 50 MB
FRONTEND_URL=http://localhost:3000

# ─── Auth ────────────────────────────────────────────────────────────────────
# MUST be overridden in production. Generate with: openssl rand -hex 32
JWT_SECRET_KEY=change-me-in-production-super-secret-key

# ─── AI / LLM ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ─── Billing (Stripe) ────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PROFESSIONAL=
STRIPE_PRICE_ENTERPRISE=

# ─── Email (Resend) ──────────────────────────────────────────────────────────
RESEND_API_KEY=
SUPPORT_EMAIL=support@depart.io

# ─── Web ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000

# ─── Oracle test container (only used when `make oracle-up`) ─────────────────
ORACLE_PASSWORD=depart_oracle_pw
ORACLE_APP_PASSWORD=hr_pw
