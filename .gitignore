# License signing private keys — must never be committed.
# Dev keys live at ~/.hafen-keys/. Production keys are managed
# out-of-band. The public key at apps/api/src/license/public_key.pem
# is the verification key and ships with the product image.
*_private*.pem
license_private*.pem

# Air-gap bundle build output — large tarballs with docker images.
/dist/
